\section{충전전류 계산}

\[
I_c[\mathrm{A}] =
\frac{2\pi f C V}{\sqrt{3}\times 1000}
\times D_{\mathrm{total}}
\]

\begin{tabularx}{\textwidth}{>{\bfseries}p{45mm}X}
적용 길이 & \VAR{route_length_km} km $\times$ \VAR{circuit_count} 회선 = \VAR{total_length_km} km \\
단위 전류 & \VAR{charging_current_per_km_a} A/km \\
적용 식 & $I_c = \dfrac{2\pi \times \VAR{frequency_hz} \times \VAR{capacitance_uf_per_km} \times \VAR{line_voltage_kv}}{\sqrt{3}\times 1000} \times \VAR{total_length_km}$ \\
충전전류 & \VAR{charging_current_a} A \\
\end{tabularx}

\begin{summarybox}
\begin{itemize}[leftmargin=6mm, itemsep=2pt, topsep=4pt]
